# =====================================================
#  Mai HR Bot — cấu hình
#  Điền các giá trị bên dưới rồi save file (đổi tên thành .env nếu cần)
# =====================================================

# --- LARK (lấy ở: https://open.larksuite.com/app/cli_a971310b12b8deea/baseinfo) ---
# App ID đã pre-fill sẵn (không cần đổi)
LARK_APP_ID=cli_a971310b12b8deea

# App Secret — copy từ "Credentials & Basic Info" → App Credentials → App Secret
LARK_APP_SECRET=DAN_APP_SECRET_VAO_DAY

# --- LARK Event Subscription Encryption (để TRỐNG nếu Lark không bật mã hoá) ---
# Nếu trong tab "Events & Callbacks" → "Encryption Strategy" có Encrypt Key → paste vào đây.
# Nếu không có hoặc muốn bypass → để trống (RECOMMENDED khi mới setup).
LARK_ENCRYPT_KEY=
LARK_VERIFICATION_TOKEN=

# --- DIFY (lấy ở: app HR Assistant → API Access → API Key) ---
# Mở: https://cloud.dify.ai/app/cc651293-1f1d-4011-93b1-f808f15034b1/develop
# Click "API Access" ở menu trái → click icon chìa khoá → tạo / copy API Key
DIFY_API_KEY=app-DAN_DIFY_API_KEY_VAO_DAY

# Dify endpoint (mặc định cho Dify Cloud, không cần đổi)
DIFY_BASE=https://api.dify.ai/v1
